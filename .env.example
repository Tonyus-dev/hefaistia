# Frontend (públicas, embutidas pelo Vite)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_ANON_KEY=

# URL local da Kaline Offline (local-server), usada pela ação "Buscar do Offline"
VITE_KALINE_OFFLINE_LOCAL_URL=http://127.0.0.1:64113

# Supabase server-side
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Chave compartilhada com a Kaline Offline (local-server/.env) para o bridge
# "Olhar de Kairós" — GET /api/bridge/olhar-de-kairos. Em produção configure via
# `wrangler secret put KALINE_BRIDGE_SHARED_KEY` (não vai em [vars] do wrangler.toml).
KALINE_BRIDGE_SHARED_KEY=

# Segredo opcional para ver detalhes (schema/latências/erros) em GET
# /api/public/ready via header `x-ready-secret`. Sem isso configurado, o
# endpoint público responde só {status}. Configure via
# `wrangler secret put KALINE_READY_SECRET` (não vai em [vars] do wrangler.toml).
KALINE_READY_SECRET=

# OpenRouter server-side
OPENROUTER_API_KEY=
OPENROUTER_CHAT_MODEL=
OPENROUTER_FAST_MODEL=
OPENROUTER_REASONING_MODEL=
OPENROUTER_TRANSCRIBE_MODEL=
OPENROUTER_IMAGE_MODEL=
OPENROUTER_TTS_MODEL=
OPENROUTER_TTS_VOICE=
OPENROUTER_MODEL_PRIMARY=
OPENROUTER_TEXT_MODEL_PRIMARY=
OPENROUTER_STT_PRIMARY_MODEL=
OPENROUTER_VISION_MODEL_PRIMARY=
OPENROUTER_TTS_PRIMARY_MODEL=
OPENROUTER_APP_NAME=
OPENROUTER_SITE_URL=

# Fallbacks automáticos (já têm default hardcoded no código — só precisam ser
# setados para sobrescrever o valor padrão):
# chat: google/gemini-2.5-flash-lite → poolside/laguna-xs-2.1
# STT:  google/gemini-2.5-flash-lite → openai/whisper-large-v3
# TTS:  google/gemini-3.1-flash-tts-preview (Vindemiatrix) → hexgrad/kokoro-82m (pf_dora)
OPENROUTER_CHAT_MODEL_FALLBACK=
OPENROUTER_STT_FALLBACK_MODEL=
OPENROUTER_TTS_FALLBACK_MODEL=
OPENROUTER_TTS_FALLBACK_VOICE=

# URL pública do app, usada em headers de providers externos
APP_PUBLIC_URL=

# Teto diário de respostas de IA por guardião no chat público da Kuan-Yin
# (páginas /g/$guardianId), contado em kuanyin_public_chat_messages. Padrão: 200.
KALINE_KUANYIN_PUBLIC_DAILY_CAP=

# Providers opcionais
GROQ_API_KEY=
