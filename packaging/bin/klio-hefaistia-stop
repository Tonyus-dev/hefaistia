#!/usr/bin/env bash
set -euo pipefail

STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/klio-hefaistia"

for PID_FILE in "$STATE_DIR/runtime.pid" "$STATE_DIR/runtime-tailnet.pid"; do
  if [ ! -f "$PID_FILE" ]; then
    continue
  fi

  PID=$(cat "$PID_FILE" || true)
  if [ -z "$PID" ]; then
    rm -f "$PID_FILE"
    continue
  fi

  if ! ps -p "$PID" >/dev/null 2>&1; then
    echo "Processo $PID não está rodando."
    rm -f "$PID_FILE"
    continue
  fi

  CMD_LINE=$(ps -p "$PID" -o args= || true)
  if [[ "$CMD_LINE" == *"server/hefaistia.mjs"* ]]; then
    NAME=$(basename "$PID_FILE" .pid)
    echo "Enviando SIGTERM para o processo $PID (Hefaístia $NAME)..."
    kill -TERM "$PID"
    echo "Aguardando encerramento..."
    
    for _ in $(seq 1 10); do
      if ! ps -p "$PID" >/dev/null 2>&1; then
        echo "Processo $PID encerrado com sucesso."
        rm -f "$PID_FILE"
        PID=""
        break
      fi
      sleep 0.5
    done

    if [ -n "$PID" ] && ps -p "$PID" >/dev/null 2>&1; then
      echo "O processo $PID não encerrou a tempo. Pode ser necessário matar manualmente (kill -9 $PID)."
    fi
  else
    echo "Processo $PID não parece ser a Hefaístia ($CMD_LINE)."
    echo "Abortando para evitar matar processo errado."
  fi
done
