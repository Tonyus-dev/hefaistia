#!/usr/bin/env bash
set -euo pipefail

STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/klio-hefaistia"
PID_FILE="$STATE_DIR/runtime.pid"

if [ ! -f "$PID_FILE" ]; then
  echo "Nenhum PID file encontrado em $PID_FILE."
  echo "Runtime provavelmente não foi iniciado pelo launcher."
  exit 0
fi

PID=$(cat "$PID_FILE")

if [ -z "$PID" ]; then
  echo "PID file vazio."
  exit 0
fi

if ! ps -p "$PID" >/dev/null 2>&1; then
  echo "Processo $PID não está rodando."
  rm -f "$PID_FILE"
  exit 0
fi

CMD_LINE=$(ps -p "$PID" -o args= || true)

if [[ "$CMD_LINE" == *"server/hefaistia.mjs"* ]]; then
  echo "Enviando SIGTERM para o processo $PID (Hefaístia)..."
  kill -TERM "$PID"
  echo "Aguardando encerramento..."
  
  for _ in $(seq 1 10); do
    if ! ps -p "$PID" >/dev/null 2>&1; then
      echo "Processo encerrado."
      rm -f "$PID_FILE"
      exit 0
    fi
    sleep 0.5
  done

  echo "O processo não encerrou a tempo. Pode ser necessário matar manualmente (kill -9 $PID)."
else
  echo "Processo $PID não parece ser a Hefaístia (server/hefaistia.mjs)."
  echo "Comando atual: $CMD_LINE"
  echo "Abortando para evitar matar processo errado."
fi
