#!/usr/bin/env bash
set -euo pipefail

URL="http://127.0.0.1:4518"
HEALTH="$URL/api/health"
APP_DIR="/opt/klio-hefaistia"

STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/klio-hefaistia"
PID_FILE="$STATE_DIR/runtime.pid"
LOG_FILE="$STATE_DIR/runtime.log"

mkdir -p "$STATE_DIR"

get_token() {
  /usr/bin/node -e '
  const fs = require("fs");
  const path = require("path");
  const crypto = require("crypto");
  const home = require("os").homedir();
  const base = process.env.XDG_CONFIG_HOME || path.join(home, ".config");
  const dir = path.join(base, "klio-hefaistia");
  const file = path.join(dir, "config.json");
  try { fs.mkdirSync(dir, { recursive: true, mode: 0o700 }); } catch {}
  try { fs.chmodSync(dir, 0o700); } catch {}
  let token;
  try {
    const config = JSON.parse(fs.readFileSync(file, "utf8"));
    token = config.token;
  } catch {
    token = crypto.randomBytes(32).toString("base64url");
    fs.writeFileSync(file, JSON.stringify({ token, created_at: new Date().toISOString() }, null, 2), { mode: 0o600 });
  }
  try { fs.chmodSync(file, 0o600); } catch {}
  console.log(token);
  '
}

is_running() {
  curl -fsS --max-time 2 "$HEALTH" >/dev/null 2>&1
}

start_runtime() {
  if is_running; then
    return 0
  fi

  echo "Iniciando Klio Hefaístia..."
  get_token >/dev/null
  (
    cd "$APP_DIR"
    KLIO_HOST=127.0.0.1 \
    KLIO_PORT=4518 \
    NODE_ENV=production \
    nohup /usr/bin/node "$APP_DIR/server/hefaistia.mjs" >>"$LOG_FILE" 2>&1 &
    echo $! > "$PID_FILE"
  )

  for _ in $(seq 1 20); do
    if is_running; then
      return 0
    fi
    sleep 0.5
  done

  echo "A Hefaístia não respondeu em $HEALTH."
  echo "Veja os logs em: $LOG_FILE"
  return 1
}

open_app() {
  local token=$(get_token)
  local app_url="$URL/#token=$token"

  if command -v google-chrome >/dev/null 2>&1; then
    exec google-chrome --app="$app_url"
  elif command -v chromium >/dev/null 2>&1; then
    exec chromium --app="$app_url"
  elif command -v chromium-browser >/dev/null 2>&1; then
    exec chromium-browser --app="$app_url"
  elif command -v brave-browser >/dev/null 2>&1; then
    exec brave-browser --app="$app_url"
  elif command -v microsoft-edge >/dev/null 2>&1; then
    exec microsoft-edge --app="$app_url"
  else
    exec xdg-open "$app_url"
  fi
}

start_runtime
open_app
